{
    "name": "gemorroj/syntax",
    "type": "library",
    "description": "PHP code syntax checker.",
    "license": "LGPL-3.0-or-later",
    "require": {
        "php": ">=8.1",
        "symfony/process": "^6.4||^7.4||^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6.31",
        "friendsofphp/php-cs-fixer": "^3.91.3"
    },
    "authors": [
        {
            "name": "Gemorroj"
        }
    ],
    "autoload": {
        "psr-4": {
            "Syntax\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Syntax\\Tests\\": "tests/"
        }
    }
}
